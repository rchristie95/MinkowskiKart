<?xml version="1.0"?>
<powerup>
  <!-- Minkowski Kart - Relativistic Powerups
       Order must match PowerupType enum in powerup_manager.hpp:
       warp-bubble, neutron-star, black-hole, zipper, photon,
       frame-shift, tidal-arm, geodesic-missile, time-dilation, mass-spike -->

  <!-- WARP BUBBLE: shield sphere (was bubblegum) -->
  <item name="warp-bubble"     icon="warp-bubble-icon.png" />

  <!-- NEUTRON STAR: fast dense lobbed projectile (Cake flyable) -->
  <item name="neutron-star"    icon="neutron-star-icon.png"
        model="cake.spm"       speed="50"
        min-height="0.2"       max-height="1.0"
        force-updown="25"      max-distance="90" />

  <!-- POCKET BLACK HOLE: slow homing gravitational ball (Bowling flyable) -->
  <item name="black-hole"      icon="black-hole-icon.png"
        model="bowling.spm"    speed="4.0"
        min-height="0.2"       max-height="1.0"
        force-updown="1"       force-to-target="40"
        max-distance="30" />

  <!-- ZIPPER: speed boost (unchanged) -->
  <item name="zipper"          icon="zipper_collect.png" />

  <!-- PHOTON: exchanged photon tether forward / Doppler flare backward -->
  <item name="photon"          icon="photon-icon.png"
        model="plunger.spm"    speed="40"
        min-height="0.2"       max-height="1.0"
        force-updown="35"      force-to-target="15"
        max-distance="30" />

  <!-- FRAME SHIFT: transforms items on track (was switch) -->
  <item name="frame-shift"     icon="frame-shift-icon.png" />

  <!-- TIDAL ARM: close-range distortion melee (was swatter) -->
  <item name="tidal-arm"       icon="tidal-arm-icon.png" />

  <!-- GEODESIC MISSILE: space-following homing projectile (was rubber-ball) -->
  <item name="geodesic-missile" icon="geodesic-missile-icon.png"
        model="rubber_ball.spm"
        speed="42.0"
        min-speed-offset="9.0"
        max-speed-offset="29.0"
        min-offset-distance="50.0"
        max-offset-distance="250.0"
        interval="1"
        max-height="4.0"      min-height="0"
        fast-ping-distance="50"
        early-target-factor="1"
        target-distance="15"  target-max-angle="90"
        min-interpolation-distance="5"
        squash-slowdown="0.5" squash-duration="2"
        delete-time="5.0"     max-height-difference="10" />

  <!-- TIME-DILATION FIELD: slows karts ahead (was parachute) -->
  <item name="time-dilation"   icon="time-dilation-icon.png"
        model="parachute.spm" />

  <!-- MASS SPIKE: weight penalty on leader (was anchor/anvil) -->
  <item name="mass-spike"      icon="mass-spike-icon.png"
        model="anchor.spm" />

