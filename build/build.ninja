#############################################
# Utility command for edit_cache

build lib/irrlicht/CMakeFiles/edit_cache.util: CUSTOM_COMMAND
  COMMAND = C:\WINDOWS\system32\cmd.exe /C "cd /D "C:\stk\build\lib\irrlicht" && "C:\stk\.build-tools\cmake\cmake-4.3.1-windows-x86_64\bin\cmake-gui.exe" -S"C:\stk" -B"C:\stk\build""
  DESC = Running CMake cache editor...
  pool = console
  restat = 1

build lib/irrlicht/edit_cache: phony lib/irrlicht/CMakeFiles/edit_cache.util


#############################################
# Utility command for rebuild_cache

build lib/irrlicht/CMakeFiles/rebuild_cache.util: CUSTOM_COMMAND
  COMMAND = C:\WINDOWS\system32\cmd.exe /C "cd /D "C:\stk\build\lib\irrlicht" && "C:\stk\.build-tools\cmake\cmake-4.3.1-windows-x86_64\bin\cmake.exe" --regenerate-during-build -S"C:\stk" -B"C:\stk\build""
  DESC = Running CMake to regenerate build system...
  pool = console
  restat = 1

build lib/irrlicht/rebuild_cache: phony lib/irrlicht/CMakeFiles/rebuild_cache.util


#############################################
# Utility command for list_install_components

build lib/irrlicht/list_install_components: phony


#############################################
# Utility command for install

build lib/irrlicht/CMakeFiles/install.util: CUSTOM_COMMAND lib/irrlicht/all
  COMMAND = C:\WINDOWS\system32\cmd.exe /C "cd /D "C:\stk\build\lib\irrlicht" && "C:\stk\.build-tools\cmake\cmake-4.3.1-windows-x86_64\bin\cmake.exe" -P cmake_install.cmake"
  DESC = Install the project...
  pool = console
  restat = 1

build lib/irrlicht/install: phony lib/irrlicht/CMakeFiles/install.util


#############################################
# Utility command for install/local

build lib/irrlicht/CMakeFiles/install/local.util: CUSTOM_COMMAND lib/irrlicht/all
  COMMAND = C:\WINDOWS\system32\cmd.exe /C "cd /D "C:\stk\build\lib\irrlicht" && "C:\stk\.build-tools\cmake\cmake-4.3.1-windows-x86_64\bin\cmake.exe" -DCMAKE_INSTALL_LOCAL_ONLY=1 -P cmake_install.cmake"
  DESC = Installing only the local directory...
  pool = console
  restat = 1

build lib/irrlicht/install/local: phony lib/irrlicht/CMakeFiles/install/local.util


